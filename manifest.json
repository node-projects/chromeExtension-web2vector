{
  "manifest_version": 3,
  "name": "Web2Vector",
  "description": "Export any web page to vector formats (like SVG, DXF, PDF) or raster formats (like PNG, JPEG, WebP) using layout2vector",
  "version": "1.0.0",
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png"
    },
    "default_title": "Web2Vector — Export page"
  },
  "permissions": [
    "activeTab",
    "downloads",
    "scripting",
    "contextMenus"
  ],
  "background": {
    "service_worker": "service-worker.js"
  }
}
